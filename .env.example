# Copy to .env and fill in.
# Server-side only — these are NOT exposed to the browser.

# Used by /api/chat (Vercel AI SDK + OpenRouter).
OPENROUTER_API_KEY=sk-or-v1-...

# Optional. Any OpenRouter model slug. Examples:
#   anthropic/claude-sonnet-4.5
#   openai/gpt-4o
#   google/gemini-2.5-flash
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Used by /api/research (Google Gemini SDK with Google Search grounding).
# Free tier: ~1,500 requests/day, no card. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# MongoDB Atlas connection. Free M0 tier works fine.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=alchemy
